# Copy this file to .env and fill in your values.

# Your bot's token, from the Discord Developer Portal -> Bot -> Reset Token.
DISCORD_TOKEN=

# Your application's Client ID, from the Developer Portal -> General Information.
CLIENT_ID=

# Optional: a single guild (server) ID for instant command registration during
# development. Leave blank to register commands globally (takes up to 1 hour).
GUILD_ID=
