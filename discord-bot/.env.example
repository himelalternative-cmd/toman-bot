# Copy this file to .env and fill in your values.

# Your bot's token, from the Discord Developer Portal -> Bot -> Reset Token.
DISCORD_TOKEN=

# Your application's Client ID, from the Developer Portal -> General Information.
CLIENT_ID=

# Optional: a single guild (server) ID for instant command registration during
# development. Leave blank to register commands globally (takes up to 1 hour).
GUILD_ID=

# Optional: absolute path to a persistent, writable directory (e.g. a Railway
# Volume's mount path) where all JSON data and voice recordings are stored.
# Leave blank to use the in-repo data/ folder (fine for local dev, but on
# Railway/most hosts that resets on every redeploy since it's not a volume).
DATA_DIR=
